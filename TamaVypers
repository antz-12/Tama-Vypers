local car = script.Parent
local seat = car:WaitForChild("VehicleSeat")
local runService = game:GetService("RunService")

local speed = 0
local maxSpeed = 180
local acceleration = 4
local brakePower = 8
local turnSpeed = 3

local fuel = 100
local maxFuel = 100

runService.Heartbeat:Connect(function()

	if seat.Occupant then
		
		local throttle = seat.Throttle
		local steer = seat.Steer
		
		-- fuel consumption
		if throttle ~= 0 then
			fuel -= 0.03
		end
		
		if fuel <= 0 then
			speed = 0
			car.PrimaryPart.Velocity = Vector3.new(0,0,0)
			return
		end
		
		-- acceleration
		if throttle == 1 then
			speed = math.clamp(speed + acceleration, -maxSpeed, maxSpeed)
		elseif throttle == -1 then
			speed = math.clamp(speed - brakePower, -maxSpeed, maxSpeed)
		else
			speed = speed * 0.98
		end
		
		-- steering
		car:SetPrimaryPartCFrame(
			car.PrimaryPart.CFrame *
			CFrame.Angles(0, math.rad(steer * turnSpeed), 0)
		)
		
		car.PrimaryPart.Velocity = car.PrimaryPart.CFrame.LookVector * speed
		
	end

end)

local player = game.Players.LocalPlayer
local gui = player.PlayerGui:WaitForChild("CarUI")

local speedLabel = gui.Speed
local fuelLabel = gui.Fuel

while true do
	
	task.wait(0.1)
	
	local character = player.Character
	
	if character then
		
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		
		if humanoid and humanoid.SeatPart then
			
			local seat = humanoid.SeatPart
			
			local speed = seat.Velocity.Magnitude
			
			speedLabel.Text = "Speed : "..math.floor(speed).." km/h"
			
		else
			
			speedLabel.Text = "Speed : 0 km/h"
			
		end
		
	end
	
end

